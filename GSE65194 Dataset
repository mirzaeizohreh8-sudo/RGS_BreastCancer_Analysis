  filter(Gene_Symbol != "" & !is.na(Gene_Symbol)) %>% # Remove unannotated probes
  # Calculate mean expression across all GSM sample columns
  mutate(Mean_Expr = rowMeans(select(., starts_with("GSM")), na.rm = TRUE)) %>%
  group_by(Gene_Symbol) %>%
  # Keep the single probe with the highest mean expression per gene
  slice_max(order_by = Mean_Expr, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  select(-Mean_Expr) # Remove the temporary Mean_Expr column

# =========================================================================
# 5. Prepare Matrix for limma
# =========================================================================
ex_matrix_GSE65194 <- ex_max_mean %>%
  select(-ID) %>% # Drop the probe ID column
  column_to_rownames("Gene_Symbol") # Set Gene_Symbol as row names

# Convert to matrix and enforce numeric data type to prevent limma errors
ex_matrix_GSE65194 <- as.matrix(ex_matrix_GSE65194)
mode(ex_matrix_GSE65194) <- "numeric"

# =========================================================================
# 6. Differential Expression Analysis (limma)
# =========================================================================
# Define experimental conditions as a factor
Condition <- factor(pdata_filtered$Condition, levels = c("Normal", "Tumor"))

# Create Design Matrix
design <- model.matrix(~ 0 + Condition)
colnames(design) <- c("Normal", "Tumor")

# Create Contrast Matrix (Tumor vs Normal)
cont_matrix <- makeContrasts(Tumor_vs_Normal = Tumor - Normal, levels = design)

# Fit the linear model
fit <- lmFit(ex_matrix_GSE65194, design)
fit2 <- contrasts.fit(fit, cont_matrix)
fit2 <- eBayes(fit2)

# =========================================================================
# 7. Extract Results
# =========================================================================
# Extract top genes with False Discovery Rate (FDR) adjustment
results_GSE65194 <- topTable(fit2, adjust = "fdr", number = Inf)

# Add Dataset identifier column for the downstream Meta-Analysis phase
results_GSE65194$Dataset <- "GSE65194"
results_GSE65194$Gene_Symbol <- rownames(results_GSE65194)

# Save the final processed results
write.csv(results_GSE65194, "GSE65194_limma_results.csv", row.names = FALSE)
print("Analysis for GSE65194 completed successfully!")
