# =========================================================================
# Project: Microarray Meta-Analysis
# Dataset: GSE65194
# Description: Downloading data, filtering cell lines, Max Mean probe 
#              selection, and Differential Expression Analysis using limma.
# =========================================================================

# 1. Load Required Libraries
library(GEOquery)
library(limma)
library(dplyr)
library(tibble)

# =========================================================================
# 2. Download and Load Dataset
# =========================================================================
print("Downloading GSE65194...")
# getGPL = FALSE is used to prevent timeout errors during download
gse <- getGEO("GSE65194", GSEMatrix = TRUE, getGPL = FALSE) 
gse <- gse[[1]]

# Extract expression matrix and phenotype (sample) data
ex <- exprs(gse)
pdata <- pData(gse)

# =========================================================================
# 3. Filter Samples (Keep Normal and Tumor, Remove Cell Lines)
# =========================================================================
# Identifying Normal (Healthy) and Tumor samples while filtering out cell lines
pdata_filtered <- pdata %>%
  rownames_to_column("Sample_ID") %>%
  # Filter out samples containing the word "cell line"
  filter(!grepl("cell line", `sample_group:ch1`, ignore.case = TRUE)) %>%
  # Categorize remaining samples into "Normal" and "Tumor"
  mutate(Condition = ifelse(grepl("Healthy", `sample_group:ch1`, ignore.case = TRUE), "Normal", "Tumor")) %>%
  column_to_rownames("Sample_ID")

# Subset the expression matrix to match the filtered samples
ex_filtered <- ex[, rownames(pdata_filtered)]

# =========================================================================
# 4. Probe to Gene Mapping & Max Mean Selection
# =========================================================================
# NOTE: Assume 'gpl_data' is your platform annotation dataframe containing 'ID' and 'Gene_Symbol'
